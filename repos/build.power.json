[
  {
    "kernelName": "power",
    "kernelSource": {
      "device": "begonia",
      "defconfig": "begonia_user_defconfig",
      "name": "begonia",
      "repo": "https://github.com/Hydra-Kernels/Hydra_Begonia.git",
      "branch": "13.x"
    },
    "withRoot": "none",
    "withSUSFS": false,
    "withKPM": false,

    "toolchains": [
      {
        "repo": "https://android.googlesource.com/platform/prebuilts/clang/host/linux-x86",
        "branch": "main",
        "name": "clang-r547379",
        "binPath": [
          "./clang-r547379/bin"
        ]
      }
    ],

    "ccache": true,

    "params": {
      "ARCH": "arm64",
      "CC": "clang-r547379/bin/clang",

      "externalCommand": {
        "CROSS_COMPILE": "clang-r547379/bin/aarch64-linux-gnu-",
        "CROSS_COMPILE_ARM32": "clang-r547379/bin/arm-linux-gnueabi-",

        "LD": "clang-r547379/bin/ld.lld",

        "LLVM": "1",
        "LLVM_IAS": "1",
        "KCFLAGS": "-Wno-error",

        "AR": "clang-r547379/bin/llvm-ar",
        "NM": "clang-r547379/bin/llvm-nm",
        "OBJCOPY": "clang-r547379/bin/llvm-objcopy",
        "OBJDUMP": "clang-r547379/bin/llvm-objdump",
        "READELF": "clang-r547379/bin/llvm-readelf",
        "OBJSIZE": "clang-r547379/bin/llvm-size",
        "STRIP": "clang-r547379/bin/llvm-strip",

        "LLVM_AR": "clang-r547379/bin/llvm-ar",
        "LLVM_DIS": "clang-r547379/bin/llvm-dis"
      }
    },

    "AnyKernel3": {
      "use": true,
      "release": true,
      "repo": "https://github.com/cvnertnc/AnyKernel3/",
      "branch": "begonia"
    }
  }
]
