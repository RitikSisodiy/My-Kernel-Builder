[
  {
    "kernelName": "power",
    "kernelSource": {
      "device": "begonia",
      "defconfig": "begonia_user_defconfig",
      "name": "begonia",
      "repo": "https://github.com/Hydra-Kernels/Hydra_Begonia.git",
      "branch": "13.x"
    },
    "withRoot": "none",
    "withSUSFS": false,
    "withKPM": false,
    "toolchains": [
      {
        "repo": "https://github.com/Neutron-Toolchains/clang",
        "branch": "master",
        "name": "NeutronClang",
        "binPath": ["bin"]
      }
    ],
    "ccache": true,
    "params": {
      "ARCH": "arm64",
      "CC": "NeutronClang/bin/clang",
      "externalCommand": {
        "CROSS_COMPILE": "NeutronClang/bin/aarch64-linux-gnu-",
        "CROSS_COMPILE_ARM32": "NeutronClang/bin/arm-linux-gnueabi-",
        "LD": "NeutronClang/bin/ld.lld",
        "LLVM": "1",
        "LLVM_IAS": "1",
        "AR": "NeutronClang/bin/llvm-ar",
        "NM": "NeutronClang/bin/llvm-nm",
        "OBJCOPY": "NeutronClang/bin/llvm-objcopy",
        "OBJDUMP": "NeutronClang/bin/llvm-objdump",
        "READELF": "NeutronClang/bin/llvm-readelf",
        "OBJSIZE": "NeutronClang/bin/llvm-size",
        "STRIP": "NeutronClang/bin/llvm-strip"
      }
    },
    "AnyKernel3": {
      "use": true,
      "release": true,
      "repo": "https://github.com/cvnertnc/AnyKernel3/",
      "branch": "begonia"
    }
  }
]
